		## isAndroid=Fgt
		isAndroid=$(grep -Eo ',\w+=!!\(.+&&.+\.indexOf\("Android"\)>=0\);' "${js}" | cut -d= -f1 | sed s/,//)
		test -n "${isAndroid}"

		# {if(this.delegate.canRelayout===!1&&!(Rl&&Qh.pointerEvents)){this.hide();return}

		## -	{if(this.j.canRelayout===!1&&!(Ol&&Lg.pointerEvents)){this.hide();return}
