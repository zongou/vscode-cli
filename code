			msg "Restoring files..."
			for file in "${js}" "${html}"; do
				cp "${file}${ext_origin}" "${file}"
			done
		}

		on_error() {
			printf "Exiting due to failure.\n" >&2
			restore_files
			exit 1
		}

		on_interrupt() {
			trap - EXIT
