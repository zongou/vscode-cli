		# ## +	;c.classList.add("context-view-pointerBlock"),o.add(K(c,ne.POINTER_MOVE,()=>c.remove())),o.add(K(c,ne.MOUSE_DOWN,()=>c.remove())),o.add(K(c,"touchstart",()=>c.remove())),o.add(K(c,"touchmove",()=>c.remove()));
		# sed -E -i 's^(,.\.add\(\w\(\w,)(..\.MOUSE_DOWN)(,\(\)=>.\.remove\(\)\)\))(;)^\1\2\3\1"touchstart"\3\1"touchmove"\3\4^g' "${js}"
		# grep -E -o -q ',\w\.add\(\w+\(\w+,\w+\.MOUSE_DOWN,\(\)=>\w+\.remove\(\)\)\),\w+\.add\(\w+\(\w+,"touchstart",\(\)=>\w+\.remove\(\)\)\),\w+\.add\(\w+\(\w+,"touchmove",\(\)=>\w+\.remove\(\)\)\);' "${js}"

		# ## -	,this.B(this.a.onDidLayoutChange(()=>this.r.hide()))}
		# ## +	,npt||this.B(this.a.onDidLayoutChange(()=>this.r.hide()))}
		# sed -E -i "s^(,)(this\\.\w\\(this\\.a\\.onDidLayoutChange\\(\\(\\)=>this\\.\w\\.hide\\(\\)\\)\\)\\})^\1${isAndroid}||\2^g" "${js}"
		# grep -E -o -q ',.{1,3}\|\|this\.\w\(this\.a\.onDidLayoutChange\(\(\)=>this\.\w\.hide\(\)\)\)\}' "${js}"

		## keyboard does not show in insiders
		## "editor.experimentalEditContextEnabled": false
		## https://github.com/microsoft/vscode/commit/3ff1dceedf606ee5cc60ffab6c1132b91ce67228

		msg "patch: fix vsce-sign of extension installing"
		echo "${verify_patch}" | patch -su ${installation_root}/node_modules/@vscode/vsce-sign/src/main.js

		msg "patch: creating revert patch"
		(
			cd "${workbench_dir}"
			diff -u "workbench.js${ext_origin}" "workbench.js" >"${revert_patch}" || test -f "${revert_patch}"
			diff -u "workbench.html${ext_origin}" workbench.html >>"${revert_patch}" || test -f "${revert_patch}"
		)

		msg "patch: removing backup"
