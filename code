revert_patch() {
	if [ $# -gt 0 ]; then
		case "$1" in
		help | -h | --help)
			# shellcheck disable=SC2059
			printf "\
Revert patch\n\

${BLD}${UND}Usage:${RST} ${BLD}${PROGRAM} patch${RST} [INSTALLATION_ROOT]\n"
			return 0
			;;
		*) ;;
		esac
	fi
	get_installation_info "$@"
	if [ -f "${revert_patch}" ]; then
		(
			cd "${installation_root}/out/vs/code/browser/workbench"
			patch -sup0 -R <"${revert_patch}"
			echo "${verify_patch}" | patch -suR "${installation_root}/node_modules/@vscode/vsce-sign/src/main.js"
			rm "${revert_patch}"
			msg "revert: done reverting in ${installation_root}"
		)
	else
		msg "revert: nothing to revert in ${installation_root}"
	fi
}

code_cli() {
	if [ ! -f "/lib/ld-musl-$(uname -m).so.1" ] && [ -x /system/bin/linker ]; then
		proot_musl_run "${CODE}" "$@"
	else
		"${CODE}" "$@"
	fi
}

main() {
	if ! ([ $# -ge 2 ] && ([ "$1" = "patch" ] || [ "$1" = "revert" ])); then
		BLD='' UND='' RST='' && if [ -t 1 ]; then BLD='\033[1m' UND='\033[4m' RST='\033[0m'; fi
		case "${PROGRAM}" in
		*-insiders) QUALITY=insider CODE=${DATA_DIR}/code-insiders ;;
		*) QUALITY=stable CODE=${DATA_DIR}/code ;;
		esac
		prepare_vscode_cli
	fi

	if [ $# -gt 0 ]; then
		case "$1" in
		help | -h | --help)
			"${CODE}" "$@"

			# shellcheck disable=SC2059
			printf "\n${BLD}${UND}CUSTOM COMMANDS:${RST}\n\
      ${BLD}patch${RST}                          Patch vscode to work better on Android\n\
      ${BLD}revert${RST}                         Revert patch\n"
			;;
		serve-web)
			code_cli "$@"
			;;
		patch)
			shift
			patch_for_android "$@"
			;;
		revert)
			shift
			revert_patch "$@"
			;;
		*)
			code_cli "$@"
			;;
		esac
	else
		code_cli "$@"
	fi
}

main "$@"
