		# 		;this.inertia(e,b,o,Math.abs(f)/g,f>0?1:-1,p,Math.abs(v)/g,v>0?1:-1,m)}this.dispatchEvent(this.newGestureEvent(On.End,c.initialTarget)),delete this.activeTouches[l.identifier]}this.dispatched&&(t.preventDefault(),t.stopPropagation(),this.dispatched=!1)}
		# 		;this.inertia(e,b,o,Math.abs(f)/g,f>0?1:-1,p,Math.abs(v)/g,v>0?1:-1,m),this.eventType=On.Change}this.dispatchEvent(this.newGestureEvent(On.End,c.initialTarget)),delete this.activeTouches[l.identifier]}this.dispatched&&(this.eventType!==On.Change&&t.preventDefault(),this.eventType=void 0,t.stopPropagation(),this.dispatched=!1)}

		sed -E -i "s#(;this\.\w+\\(\w,\w,\w,Math.abs\\(.\\)/\w,\w>0\\?1:-1,\w,Math.abs\\(.\\)/\w,\w>0\\?1:-1,\w\\))#\1,this.${var}=${EventType}.Change#g" "${js}"
		sed -E -i "s#(\\[\w\\.\w+\\]\\}this.\w+&&\\()(\w.preventDefault\\(\\),)#\\1this.${var}!==${EventType}.Change\\&\\&\\2this.${var}=void 0,#g" "${js}"
		grep -E -o -q ";this\.\w+\(\w,\w,\w,Math.abs\(.\)/\w,\w>0\?1:-1,\w,Math.abs\(.\)/\w,\w>0\?1:-1,\w\),this\.${var}=${EventType}\.Change}this\.\w+\(this\.\w+\(${EventType}\.End,\w\.\w+\)\),delete this\.\w+\[\w\.identifier\]}this\.\w+&&\(this\.eventType!==${EventType}\.Change&&t\.preventDefault\(\),this\.eventType=void 0,\w.stopPropagation\(\),this\.\w+=!1\)}" "${js}"

		viewportInteractiveWidget=resizes-content
		msg "patch: add html viewport content interactive-widget=${viewportInteractiveWidget}"
		## -	<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0, user-scalable=no">
		## +	<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0, user-scalable=no, interactive-widget=resizes-content">
		sed -E -i "s/(<meta name=\"viewport\" )(content=.+)(>$)/\1content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0, user-scalable=no, interactive-widget=${viewportInteractiveWidget}\"\3/" "${html}"
		grep -E -o -q "<meta name=\"viewport\" content=\".+, interactive-widget=${viewportInteractiveWidget}\">$" "${html}"

		msg "patch: fix context menu for android"
